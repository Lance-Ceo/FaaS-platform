# ============================================================
# FaaS Platform - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://faas:faas_secret@localhost:5432/faasdb
POSTGRES_USER=faas
POSTGRES_PASSWORD=faas_secret
POSTGRES_DB=faasdb

# ─── JWT Authentication ───────────────────────────────────────
# IMPORTANT: Change these in production! Use strong random strings.
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-prod
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-change-in-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── OpenFaaS ────────────────────────────────────────────────
OPENFAAS_GATEWAY=http://localhost:8080
OPENFAAS_USERNAME=admin
OPENFAAS_PASSWORD=admin
OPENFAAS_NAMESPACE=openfaas-fn

# ─── Docker Registry ─────────────────────────────────────────
DOCKER_REGISTRY=localhost:5000
DOCKER_REGISTRY_USERNAME=
DOCKER_REGISTRY_PASSWORD=

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Monitoring ──────────────────────────────────────────────
PROMETHEUS_ENABLED=true
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─── NATS ────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ─── Build ───────────────────────────────────────────────────
BUILD_DIR=/tmp/faas-builds
FUNCTION_IMAGE_PREFIX=faas-fn

# ─── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost/api/v1
